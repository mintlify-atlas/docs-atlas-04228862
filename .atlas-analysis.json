  "keyFeatures": [
    "60+ production-ready React components with TypeScript support",
    "Comprehensive theming system with light and dark mode support",
    "Accessible components following WCAG guidelines",
    "Semantic color variables with consistent taxonomy",
    "RTL (right-to-left) language support",
    "Design tokens and CSS foundations via Bedrock CSS",
    "Usage patterns and best-practice guidelines for common UI flows",
    "Figma integration with design assets and component documentation"
